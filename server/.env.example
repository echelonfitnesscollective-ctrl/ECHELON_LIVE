# Stripe — use Dashboard test-mode secret when developing
STRIPE_SECRET_KEY=sk_test_...

# Visible browser origin hosting your static HTML (scheme + host, no slash)
CLIENT_ORIGIN_HOST=http://127.0.0.1:5500

# Optional: subdirectory only if Live Server publishes that folder beneath host
CLIENT_PATH_PREFIX=
CLIENT_ENTRY=index.html

# CORS origins for fetch() from storefront (comma-separated). Usually mirrors CLIENT_ORIGIN_HOST
PAYMENT_ORIGINS=http://127.0.0.1:5500,http://localhost:5500

# Prefer a Stripe Dashboard Price ID for the Training Tee (optional)
# STRIPE_PRICE_TRAINING_TEE=price_...

PORT=4242
